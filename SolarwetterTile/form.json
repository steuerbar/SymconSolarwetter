{
  "elements": [
    {
      "type": "NumberSpinner",
      "name": "Latitude",
      "caption": "Breitengrad",
      "digits": 6,
      "minimum": -90,
      "maximum": 90
    },
    {
      "type": "NumberSpinner",
      "name": "Longitude",
      "caption": "Längengrad",
      "digits": 6,
      "minimum": -180,
      "maximum": 180
    },
    {
      "type": "NumberSpinner",
      "name": "RoofTilt",
      "caption": "Dachneigung in Grad",
      "digits": 1,
      "minimum": 0,
      "maximum": 90
    },
    {
      "type": "NumberSpinner",
      "name": "RoofAzimuth",
      "caption": "Open-Meteo-Azimut in Grad (-180 bis 180)",
      "digits": 1,
      "minimum": -180,
      "maximum": 180
    },
    {
      "type": "ValidationTextBox",
      "name": "Timezone",
      "caption": "Zeitzone"
    },
    {
      "type": "NumberSpinner",
      "name": "UpdateInterval",
      "caption": "Abrufintervall in Sekunden",
      "minimum": 300,
      "maximum": 86400
    },
    {
      "type": "NumberSpinner",
      "name": "PVPeakPower",
      "caption": "Installierte PV-Leistung in kWp",
      "digits": 2,
      "minimum": 0.1,
      "maximum": 1000
    },
    {
      "type": "NumberSpinner",
      "name": "PerformanceRatio",
      "caption": "Performance Ratio",
      "digits": 2,
      "minimum": 0.1,
      "maximum": 1
    },
    {
      "type": "NumberSpinner",
      "name": "InverterLimit",
      "caption": "Wechselrichtergrenze in kW",
      "digits": 2,
      "minimum": 0.1,
      "maximum": 1000
    },
    {
      "type": "CheckBox",
      "name": "UseTomorrow",
      "caption": "Kalendertag (00–24 Uhr) statt der nächsten 24 Stunden anzeigen"
    },
    {
      "type": "CheckBox",
      "name": "CalendarDayTomorrow",
      "caption": "Folgetag statt aktuellem Tag verwenden (nur im Kalendertag-Modus)"
    }
  ],
  "actions": [
    {
      "type": "Label",
      "caption": "Das Modul lädt die 72-Stunden-Prognose eigenständig von Open-Meteo. Bei kurzen Ausfällen bleibt die letzte gültige Prognose erhalten."
    },
    {
      "type": "Button",
      "caption": "Wetterdaten jetzt abrufen",
      "onClick": "SWK_UpdateData($id);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Aktiv"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Open-Meteo nicht verfügbar"
    }
  ]
}
